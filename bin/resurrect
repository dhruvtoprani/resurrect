#!/usr/bin/env node
import { cpSync, mkdtempSync, rmSync } from "node:fs";
import { tmpdir } from "node:os";
import { dirname, join } from "node:path";
import { fileURLToPath } from "node:url";
import { spawnSync } from "node:child_process";

const packageRoot = dirname(dirname(fileURLToPath(import.meta.url)));
const tempRoot = mkdtempSync(join(tmpdir(), "resurrect-cli-"));

try {
  for (const name of ["scripts", "references", "assets", "agents", "SKILL.md", "package.json"]) {
    cpSync(join(packageRoot, name), join(tempRoot, name), { recursive: true });
  }

  const result = spawnSync(
    process.execPath,
    ["--experimental-strip-types", join(tempRoot, "scripts", "resurrect.ts"), ...process.argv.slice(2)],
    {
      cwd: process.cwd(),
      stdio: "inherit",
      env: process.env,
    },
  );

  process.exit(result.status ?? 1);
} finally {
  rmSync(tempRoot, { recursive: true, force: true });
}
